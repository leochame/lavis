# ====================================
# Lavis backend runtime config (.env)
# ====================================
#
# Copy this file to ".env" in project root, then fill your real values.
# The backend loads ".env" on startup and reads keys/base URL/model settings from it.
#
# You can use either:
# 1) Direct Spring keys (recommended, explicit)
# 2) Shorthand LAVIS_* keys (mapped by DotenvLoader)
#
# ====================================
# 1) Direct Spring keys (recommended)
# ====================================

# Chat model
app.llm.models.fast-model.api-key=
app.llm.models.fast-model.base-url=
app.llm.models.fast-model.model-name=gemini-3-flash-preview

# STT model
app.llm.models.whisper.api-key=
app.llm.models.whisper.base-url=
app.llm.models.whisper.model-name=gemini-3-flash-preview
# TTS model
app.llm.models.tts.api-key=
app.llm.models.tts.model-name=gemini-2.5-flash-preview-tts
app.llm.models.tts.voice=Kore
app.llm.models.tts.format=wav

# ====================================
# 2) Optional shorthand keys
# ====================================
# LAVIS_CHAT_API_KEY=
# LAVIS_CHAT_BASE_URL=
# LAVIS_CHAT_MODEL_NAME=gemini-3-flash-preview
# LAVIS_CHAT_FORMAT=OPENAI
# LAVIS_STT_API_KEY=
# LAVIS_STT_BASE_URL=
# LAVIS_STT_MODEL_NAME=gemini-3-flash-preview
# LAVIS_STT_FORMAT=GEMINI
# LAVIS_TTS_API_KEY=
# LAVIS_TTS_MODEL_NAME=gemini-2.5-flash-preview-tts
# LAVIS_TTS_VOICE=Kore
# LAVIS_TTS_FORMAT=wav
# LAVIS_TTS_API_FORMAT=GEMINI

# Backward compatibility:
# GEMINI_API_KEY=
